    private static final class SwitchingProvider<T> implements Provider<T> {
      private final SingletonCImpl singletonCImpl;

      private final int id;

      SwitchingProvider(SingletonCImpl singletonCImpl, int id) {
        this.singletonCImpl = singletonCImpl;
        this.id = id;
      }

      @SuppressWarnings("unchecked")
      @Override
      public T get() {
        switch (id) {
          case 0: // com.m2h.m2haichatbot.domain.repository.AuthRepository 
          return (T) AppModule_ProvideAuthRepositoryFactory.provideAuthRepository(singletonCImpl.provideSupabaseServiceProvider.get(), singletonCImpl.provideSupabaseStorageProvider.get(), singletonCImpl.provideSupabaseAuthProvider.get());

          case 1: // com.m2h.m2haichatbot.data.remote.SupabaseService 
          return (T) AppModule_ProvideSupabaseServiceFactory.provideSupabaseService(singletonCImpl.provideSupabaseClientProvider.get());

          case 2: // io.github.jan.supabase.SupabaseClient 
          return (T) SupabaseModule_ProvideSupabaseClientFactory.provideSupabaseClient();

          case 3: // io.github.jan.supabase.storage.Storage 
          return (T) SupabaseModule_ProvideSupabaseStorageFactory.provideSupabaseStorage(singletonCImpl.provideSupabaseClientProvider.get());

          case 4: // io.github.jan.supabase.gotrue.Auth 
          return (T) SupabaseModule_ProvideSupabaseAuthFactory.provideSupabaseAuth(singletonCImpl.provideSupabaseClientProvider.get());

          case 5: // com.m2h.m2haichatbot.domain.repository.ChatRepository 
          return (T) AppModule_ProvideChatRepositoryFactory.provideChatRepository(singletonCImpl.provideSupabaseServiceProvider.get(), singletonCImpl.provideNvidiaAIServiceProvider.get(), singletonCImpl.provideChatDaoProvider.get(), singletonCImpl.provideMessageDaoProvider.get(), singletonCImpl.provideSupabaseStorageProvider.get(), singletonCImpl.provideSupabaseAuthProvider.get(), singletonCImpl.provideSupabasePostgrestProvider.get());

          case 6: // com.m2h.m2haichatbot.data.remote.NvidiaAIService 
          return (T) AppModule_ProvideNvidiaAIServiceFactory.provideNvidiaAIService(singletonCImpl.provideOkHttpClientProvider.get(), singletonCImpl.provideJsonProvider.get(), singletonCImpl.provideSupabaseAuthProvider.get(), singletonCImpl.preferenceRepositoryProvider.get());

          case 7: // okhttp3.OkHttpClient 
          return (T) AppModule_ProvideOkHttpClientFactory.provideOkHttpClient();

          case 8: // kotlinx.serialization.json.Json 
          return (T) AppModule_ProvideJsonFactory.provideJson();

          case 9: // com.m2h.m2haichatbot.data.repository.PreferenceRepository 
          return (T) new PreferenceRepository(ApplicationContextModule_ProvideContextFactory.provideContext(singletonCImpl.applicationContextModule));

          case 10: // com.m2h.m2haichatbot.data.local.dao.ChatDao 
          return (T) AppModule_ProvideChatDaoFactory.provideChatDao(singletonCImpl.provideM2HAIDatabaseProvider.get());

          case 11: // com.m2h.m2haichatbot.data.local.M2HAIDatabase 
          return (T) AppModule_ProvideM2HAIDatabaseFactory.provideM2HAIDatabase(ApplicationContextModule_ProvideContextFactory.provideContext(singletonCImpl.applicationContextModule));

          case 12: // com.m2h.m2haichatbot.data.local.dao.MessageDao 
          return (T) AppModule_ProvideMessageDaoFactory.provideMessageDao(singletonCImpl.provideM2HAIDatabaseProvider.get());

          case 13: // io.github.jan.supabase.postgrest.Postgrest 
          return (T) SupabaseModule_ProvideSupabasePostgrestFactory.provideSupabasePostgrest(singletonCImpl.provideSupabaseClientProvider.get());

          case 14: // com.m2h.m2haichatbot.domain.repository.ModelRepository 
          return (T) AppModule_ProvideModelRepositoryFactory.provideModelRepository(singletonCImpl.provideSupabaseServiceProvider.get(), singletonCImpl.provideAIModelDaoProvider.get());

          case 15: // com.m2h.m2haichatbot.data.local.dao.AIModelDao 
          return (T) AppModule_ProvideAIModelDaoFactory.provideAIModelDao(singletonCImpl.provideM2HAIDatabaseProvider.get());

          default: throw new AssertionError(id);
        }
      }
    }
  }
