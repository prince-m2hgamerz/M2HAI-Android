      this.provideAIModelDaoProvider = DoubleCheck.provider(new SwitchingProvider<AIModelDao>(singletonCImpl, 15));
      this.provideModelRepositoryProvider = DoubleCheck.provider(new SwitchingProvider<ModelRepository>(singletonCImpl, 14));
